{
  "name": "simple-transfer",
  "version": "3.0.0",
  "description": "Simple Transfer - Generador de Layouts de Transferencias - Aplicación de escritorio con React + TypeScript + Electron",
  "main": "dist-electron/main.js",
  "homepage": "https://github.com/GonzaDev/simple-transfer",
  "repository": {
    "type": "git",
    "url": "https://github.com/GonzaDev/simple-transfer.git"
  },
  "bugs": {
    "url": "https://github.com/GonzaDev/simple-transfer/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist dist-electron dist-react",
    "lint": "tsc --noEmit",
    "build:all": "pnpm clean && pnpm build",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux"
  },
  "keywords": [
    "simple-transfer",
    "simpletransfer",
    "transferencias",
    "layouts",
    "spei",
    "electron",
    "react",
    "typescript",
    "banking",
    "fintech"
  ],
  "author": {
    "name": "GonzaDev",
    "email": "gonzalo.gb11.ggb@gmail.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@mantine/core": "^8.3.15",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@tabler/icons-react": "^3.37.1",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^40.2.1",
    "electron-builder": "^24.13.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.gonzadev.simpletransfer",
    "productName": "Simple Transfer",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "dist-react/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.py",
      "!src/**/*",
      "!electron/**/*"
    ],
    "extraFiles": [],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
